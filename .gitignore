# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Jupyter ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ---- Testing / coverage ----
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ---- Project data & artefacts (large / regenerable) ----
# The MIT-BIH database is downloaded on demand; never commit raw signals.
data/mitdb/
data/processed/
# Trained model checkpoints.
models/*.pt
models/*.pth
# Generated outputs (figures, reports, TensorBoard logs).
outputs/tensorboard/
outputs/figures/*
outputs/confusion_matrix/*
outputs/reports/*
# ...but keep the empty directories tracked (see .gitkeep files).
!outputs/figures/.gitkeep
!outputs/confusion_matrix/.gitkeep
!outputs/reports/.gitkeep

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
